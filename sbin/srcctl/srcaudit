#!/bin/sh
# srcaudit - SourceBSD network exposure and security audit

LOG_FILE="/var/log/srcaudit.log"
POLICY_DIR="/etc/srcbsd/policies"

log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> $LOG_FILE
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

case "$1" in
  expose)
    echo "==================================="
    echo " SourceBSD - Network Exposure Audit"
    echo "==================================="
    echo ""
    printf "  %-12s %-8s %-10s %-12s %s\n" "STATUS" "PORT" "PROCESS" "EXPOSURE" "NOTE"
    echo "  ---------------------------------------------------------------"

    sockstat -l 2>/dev/null | tail -n +2 | while read USER CMD PID FD PROTO LOCAL FOREIGN; do

      # only process tcp4 tcp6 udp4 udp6
      case "$PROTO" in
        tcp4|tcp6|udp4|udp6) ;;
        *) continue ;;
      esac

      # extract port from LOCAL address
      PORT=$(echo "$LOCAL" | awk -F: '{print $NF}' | tr -d ' ')

      # skip if port is not a number
      case "$PORT" in
        ''|*[!0-9]*) continue ;;
      esac

      # check if internet facing
      case "$LOCAL" in
        \*:*|0.0.0.0:*|:::*)
          EXPOSURE="internet"
          TAG="[EXPOSED]"
          ;;
        *)
          EXPOSURE="local"
          TAG="[LOCAL]  "
          ;;
      esac

      # note for known ports
      case "$PORT" in
        22)   NOTE="SSH — OK if expected" ;;
        80)   NOTE="HTTP — OK if expected" ;;
        443)  NOTE="HTTPS — OK if expected" ;;
        514)  NOTE="Syslog — review if internet" ;;
        5432) NOTE="Postgres — UNEXPECTED public" ;;
        3306) NOTE="MySQL — UNEXPECTED public" ;;
        6379) NOTE="Redis — UNEXPECTED public" ;;
        8080) NOTE="Alt HTTP — review" ;;
        3000) NOTE="Dev server — review" ;;
        *)    NOTE="Review — verify intentional" ;;
      esac

      # flag dangerous exposures
      case "$PORT" in
        5432|3306|6379)
          if [ "$EXPOSURE" = "internet" ]; then
            TAG="[DANGER] "
          fi
          ;;
      esac

      printf "  %-12s %-8s %-10s %-12s %s\n" "$TAG" ":$PORT" "$CMD" "$EXPOSURE" "$NOTE"
    done

    echo ""
    echo "==================================="
    echo " DANGER  = fix immediately"
    echo " EXPOSED = internet facing, verify"
    echo " LOCAL   = not publicly reachable"
    echo "==================================="
    log "INFO  srcaudit expose scan completed"
    ;;

  check)
    echo "==================================="
    echo " SourceBSD - Security Audit"
    echo "==================================="
    echo ""
    ISSUES=0

    echo "[ Kernel hardening ]"

    SECURELEVEL=$(sysctl -n kern.securelevel)
    if [ "$SECURELEVEL" -lt 1 ]; then
      echo "  [WARN] kern.securelevel is $SECURELEVEL — recommend 1 or higher"
      echo "         Fix: sysctl kern.securelevel=1"
      ISSUES=$(( ISSUES + 1 ))
    else
      echo "  [OK]   kern.securelevel = $SECURELEVEL"
    fi

    COREDUMP=$(sysctl -n kern.coredump)
    if [ "$COREDUMP" = "1" ]; then
      echo "  [WARN] kern.coredump enabled — may leak sensitive data"
      echo "         Fix: sysctl kern.coredump=0"
      ISSUES=$(( ISSUES + 1 ))
    else
      echo "  [OK]   kern.coredump = $COREDUMP"
    fi

    RANDPID=$(sysctl -n kern.randompid 2>/dev/null)
    if [ "${RANDPID:-0}" = "0" ]; then
      echo "  [WARN] kern.randompid is 0 — PIDs are predictable"
      echo "         Fix: sysctl kern.randompid=1"
      ISSUES=$(( ISSUES + 1 ))
    else
      echo "  [OK]   kern.randompid = $RANDPID"
    fi

    echo ""
    echo "[ SSH hardening ]"

    ROOT_LOGIN=$(grep "^PermitRootLogin" /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}')
    if [ "$ROOT_LOGIN" = "yes" ]; then
      echo "  [WARN] PermitRootLogin is yes — disable for production"
      echo "         Fix: set PermitRootLogin no in /etc/ssh/sshd_config"
      ISSUES=$(( ISSUES + 1 ))
    else
      echo "  [OK]   PermitRootLogin = ${ROOT_LOGIN:-default}"
    fi

    PASS_AUTH=$(grep "^PasswordAuthentication" /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}')
    if [ "$PASS_AUTH" = "yes" ]; then
      echo "  [WARN] PasswordAuthentication is yes — use keys only"
      echo "         Fix: set PasswordAuthentication no in /etc/ssh/sshd_config"
      ISSUES=$(( ISSUES + 1 ))
    else
      echo "  [OK]   PasswordAuthentication = ${PASS_AUTH:-default}"
    fi

    echo ""
    echo "[ Jail security ]"

    JAIL_COUNT=$(ls $POLICY_DIR/*.policy 2>/dev/null | wc -l | tr -d ' ')
    echo "  [INFO] $JAIL_COUNT jail(s) configured"

    for POLICY in $POLICY_DIR/*.policy; do
      [ -f "$POLICY" ] || continue
      JAIL_NAME=$(basename $POLICY .policy)
      VEIL="no"
      [ -f "/var/db/srcveil/$JAIL_NAME.veil" ] && VEIL="yes"
      BACKUP=$(ls /var/backups/srcbsd/${JAIL_NAME}_*.manifest 2>/dev/null | wc -l | tr -d ' ')
      TESTED=$(grep -l "test_result=PASSED" /var/backups/srcbsd/${JAIL_NAME}_*.manifest 2>/dev/null | wc -l | tr -d ' ')
      JID=$(jls -j $JAIL_NAME jid 2>/dev/null)

      echo ""
      echo "  jail:$JAIL_NAME"

      if [ -n "$JID" ]; then
        echo "    [OK]   running — JID $JID"
      else
        echo "    [WARN] not running — start with: jail -c $JAIL_NAME"
        ISSUES=$(( ISSUES + 1 ))
      fi

      if [ "$VEIL" = "yes" ]; then
        echo "    [OK]   srcveil applied"
      else
        echo "    [WARN] srcveil not applied"
        echo "           Fix: srcveil apply $JAIL_NAME --profile minimal-trace"
        ISSUES=$(( ISSUES + 1 ))
      fi

      if [ "$BACKUP" -gt 0 ] && [ "$TESTED" -gt 0 ]; then
        echo "    [OK]   backup verified"
      elif [ "$BACKUP" -gt 0 ]; then
        echo "    [WARN] backup not tested"
        echo "           Fix: srcbackup test $JAIL_NAME"
        ISSUES=$(( ISSUES + 1 ))
      else
        echo "    [WARN] no backup found"
        echo "           Fix: srcbackup backup $JAIL_NAME"
        ISSUES=$(( ISSUES + 1 ))
      fi
    done

    echo ""
    echo "==================================="
    if [ "$ISSUES" -eq 0 ]; then
      echo " Result: PASSED — no issues found"
    else
      echo " Result: $ISSUES issue(s) found"
      echo " Run the Fix commands above to resolve"
    fi
    echo "==================================="
    log "INFO  srcaudit check completed — $ISSUES issues found"
    ;;

  tail)
    echo "==================================="
    echo " SourceBSD - Live Audit Log"
    echo "==================================="
    if [ -f "$LOG_FILE" ]; then
      tail -f $LOG_FILE
    else
      echo "No audit log yet."
    fi
    ;;

  *)
    echo "Usage: srcaudit [expose|check|tail]"
    echo ""
    echo "Commands:"
    echo "  expose   Show all open ports and exposure status"
    echo "  check    Full security audit with fix suggestions"
    echo "  tail     Stream live audit log"
    ;;
esac
